{
  "name": "terra-station",
  "description": "A web application to interact with Terra Core.",
  "homepage": "https://station.money",
  "author": "Terra <engineering@terra.money> (https://station.money)",
  "repository": "github:terra-money/station",
  "version": "7.3.5",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cross-env TSC_COMPILE_ON_ERROR=true react-scripts start",
    "build": "cross-env TSC_COMPILE_ON_ERROR=true sh -c \"echo \\\"$CF_PAGES_COMMIT_SHA\\\" > public/commit_hash\" && react-scripts build",
    "test": "react-scripts test",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "dc:up": "docker-compose up --build -d",
    "dc:logs": "docker-compose logs -f",
    "dc:down": "docker-compose down",
    "dc:purge": "docker compose rm -f -s -v && docker volume rm localterra_terra"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "^2.35.4",
    "@anchor-protocol/anchor.js": "^5.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ledgerhq/hw-transport-web-ble": "^6.27.1",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "@sentry/react": "^7.120.4",
    "@sentry/replay": "^7.120.4",
    "@sentry/tracing": "^7.120.4",
    "@terra-money/feather.js": "1.0.11",
    "@terra-money/ledger-station-js": "1.3.8",
    "@terra-money/log-finder-ruleset": "^3.0.3",
    "@terra-money/msg-reader": "^3.0.1",
    "@terra-money/station-connector": "1.1.4",
    "@terra-money/terra-station-mobile": "1.1.4",
    "@terra-money/terra-utils": "^1.1.1",
    "@terra-money/terra.js": "3.1.10",
    "@terra-money/terra.proto": "^4.0.10",
    "@terra-money/wallet-kit": "1.1.4",
    "@tippyjs/react": "^4.2.6",
    "axios": "^1.13.6",
    "bech32": "^2.0.0",
    "bignumber.js": "^9.0.2",
    "buffer": "^6.0.3",
    "classnames": "^2.3.2",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^23.12.1",
    "i18next-browser-languagedetector": "^6.1.4",
    "immutability-helper": "^3.1.1",
    "js-base64": "^3.7.2",
    "keccak256": "^1.0.6",
    "lottie-react": "^2.4.1",
    "numeral": "^2.0.6",
    "prettier": "^3.8.1",
    "qrcode.react": "^3.1.0",
    "qs": "^6.11.0",
    "ramda": "^0.28.0",
    "react": "^18.3.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^13.5.0",
    "react-modal": "^3.16.3",
    "react-query": "^3.39.3",
    "react-router-dom": "^5.3.4",
    "recharts": "^2.12.7",
    "recoil": "^0.7.7",
    "sass": "^1.97.3",
    "secp256k1": "^4.0.3",
    "semver": "^7.5.2",
    "sentence-case": "^3.0.4",
    "web-vitals": "^1.1.2",
    "xss": "1.0.11"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/numeral": "^2.0.5",
    "@types/qrcode.react": "^1.0.5",
    "@types/qs": "^6.9.17",
    "@types/ramda": "^0.28.25",
    "@types/react": "^18.3.18",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^18.3.5",
    "@types/react-modal": "^3.16.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/secp256k1": "^4.0.6",
    "@types/semver": "^7.5.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "react-error-overlay": "6.0.9",
    "react-scripts": "5.0.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "4.9.5"
  },
  "overrides": {
    "ws": "8.17.1",
    "axios": "^1.13.6"
  },
  "resolutions": {
    "react-error-overlay": "6.0.9"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,json,scss,md}": [
      "prettier --no-semi --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
